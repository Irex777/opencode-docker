{
  "$schema": "https://opencode.ai/config.json",
  "model": "anthropic/glm-5.2",
  "small_model": "anthropic/glm-5.2",
  "provider": {
    "anthropic": {
      "options": {
        "timeout": 600000,
        "chunkTimeout": 30000
      }
    }
  },
  "autoupdate": false,
  "snapshot": false,
  "permission": {
    "edit": "ask",
    "bash": "ask"
  }
}
