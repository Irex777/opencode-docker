OPENCODE_SERVER_PASSWORD=changeme
OPENCODE_SERVER_USERNAME=opencode
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# --- git project integration ---
# PAT with `repo` (and `read:org` for private org repos) scope. Used by the
# entrypoint to clone the repos below over HTTPS. Leave empty for public repos.
GITHUB_TOKEN=
# Space-separated list of owner/repo specs to clone into /workspace, e.g.
#   GITHUB_REPOS=Irex777/opencode-docker Irex777/my-project@develop
GITHUB_REPOS=
# Identity recorded on commits made inside OpenCode.
GIT_USER_NAME=
GIT_USER_EMAIL=
